# Anthropic (Claude) — required for AI analysis
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI — macro and tradfi news (https://newsapi.org)
NEWSAPI_KEY=your_newsapi_key_here

# CryptoPanic — crypto-specific news (https://cryptopanic.com/developers/api)
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# Secret to protect the cron endpoint from unauthorized calls
CRON_SECRET=your_random_secret_here

# Upstash Redis — injected automatically by Vercel after adding Upstash Redis integration
# (get these from Vercel Dashboard > Integrations > Upstash Redis, or from upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
